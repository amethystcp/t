/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_SPI2_Init();
  if (MX_FATFS_Init() != APP_OK) {
    Error_Handler();
  }
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */

    /* --- Servo PWM start (timer must be initialized by MX_TIM2_Init first) -- */
    HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_1);

    /* --- MS5607 barometer init -------------------------------------------- */
    MS5607_Init(&hspi1, BARO_CS_GPIO_Port, BARO_CS_Pin);
    
    // ดึงค่า Baro เริ่มต้นครั้งแรกเพื่อกำหนดจุดเริ่มต้นให้ Kalman
    HAL_Delay(50);
    MS5607Update();
    Kalman_Init(&kf, MS5607GetAltitudeM());

    /* --- UART startup header ---------------------------------------------- */
    const char *uartHeader = "timestamp_ms,pressure_pa,temperature_c,altitude_m,kalman_alt_m,kalman_vel_ms,servo_deg\r\n";
    HAL_UART_Transmit(&huart2, (uint8_t *)uartHeader, (uint16_t)strlen(uartHeader), HAL_MAX_DELAY);

    /* --- SD card: mount filesystem and open/create log file --------------- */
    HAL_Delay(100);
    if (f_mount(&SDFatFs, "", 1) == FR_OK) {
        if (f_open(&LogFile, "BARO_LOG.CSV", FA_OPEN_ALWAYS | FA_WRITE | FA_READ) == FR_OK) {
            f_lseek(&LogFile, f_size(&LogFile));
            if (f_size(&LogFile) == 0) {
                const char *hdr = "timestamp_ms,pressure_pa,temperature_c,altitude_m,kalman_alt_m,kalman_vel_ms,servo_deg\r\n";
                UINT bw;
                f_write(&LogFile, hdr, strlen(hdr), &bw);
                f_sync(&LogFile);
            }
            sdReady = 1;
        }
    }
    
    last_tick = HAL_GetTick(); // เริ่มจับเวลาลูปแรก

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
      while (1)
      {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

        // --- Servo oscillation range: comment one line, uncomment the other ---

        MS5607Update();
        
        // --- คำนวณ dt (Delta Time) ---
        uint32_t current_tick = HAL_GetTick();
        float dt = (float)(current_tick - last_tick) / 1000.0f;
        if (dt <= 0.001f) dt = 0.001f; // ป้องกันค่า dt เป็นศูนย์หรือติดลบ
        last_tick = current_tick;

        // --- ดึงข้อมูลและอัปเดตสถานะ ---
        liveTelemetry.timestamp     = current_tick;
        liveTelemetry.pressure_pa   = MS5607GetPressurePa();
        liveTelemetry.temperature_c = MS5607GetTemperatureC();
        liveTelemetry.altitude_m    = MS5607GetAltitudeM();

        // --- นำค่าเข้า Kalman Filter ---
        Kalman_Update(&kf, (float)liveTelemetry.altitude_m, dt);
        
        liveTelemetry.kalman_alt_m  = kf.altitude;
        liveTelemetry.kalman_vel_ms = kf.velocity;

        // --- สื่อสารผ่าน UART ---
        int len = snprintf(uartTxBuffer, sizeof(uartTxBuffer),
                           "%lu,%ld,%.2f,%.2f,%.2f,%.2f,%.2f\r\n",
                           liveTelemetry.timestamp,
                           liveTelemetry.pressure_pa,
                           liveTelemetry.temperature_c,
                           liveTelemetry.altitude_m,
                           liveTelemetry.kalman_alt_m,
                           liveTelemetry.kalman_vel_ms,
                           (double)liveTelemetry.servo_deg);
        if (len > 0) {
            HAL_UART_Transmit(&huart2, (uint8_t *)uartTxBuffer, (uint16_t)len, HAL_MAX_DELAY);
        }

        // --- บันทึกลง SD Card ---
        if (sdReady) {
            UINT bw;
            int sdLen = snprintf(sdWriteBuffer, sizeof(sdWriteBuffer),
                                 "%lu,%ld,%.2f,%.2f,%.2f,%.2f,%.2f\r\n",
                                 liveTelemetry.timestamp,
                                 liveTelemetry.pressure_pa,
                                 liveTelemetry.temperature_c,
                                 liveTelemetry.altitude_m,
                                 liveTelemetry.kalman_alt_m,
                                 liveTelemetry.kalman_vel_ms,
                                 (double)liveTelemetry.servo_deg);
            f_write(&LogFile, sdWriteBuffer, (UINT)sdLen, &bw);
            f_sync(&LogFile);
        }
        
        // --- การควบคุม Servo ---
        float servoMin =   27.0f, servoMax = 140.0f;

        static float servoPos = 0.0f;
        static float servoDir = 1.0f;
        float step = (servoMax - servoMin) / 40.0f;
 	 	servoPos += servoDir * step;
        if (servoPos >= servoMax) { servoPos = servoMax; servoDir = -1.0f; }
        if (servoPos <= servoMin) { servoPos = servoMin; servoDir =  1.0f; }
        liveTelemetry.servo_deg = servoPos;
        servoSetAngle(servoPos);

// 	 	liveTelemetry.servo_deg = servoMin;
//        servoSetAngle(servoMin);

// 	 	liveTelemetry.servo_deg = servoMax;
//        servoSetAngle(servoMax);


        HAL_Delay(100);
      }
  /* USER CODE END 3 */
}

