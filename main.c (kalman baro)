static uint32_t servoDegToUs(float deg)
{
    return (uint32_t)(SERVO_MIN_US + (deg / 180.0f) * (SERVO_MAX_US - SERVO_MIN_US));
}

static void servoSetAngle(float deg)
{
    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, servoDegToUs(deg));
}

// ฟังก์ชันเริ่มต้น Kalman Filter
void Kalman_Init(KalmanFilter_t *kf, float initial_altitude) {
    kf->altitude = initial_altitude;
    kf->velocity = 0.0f;
    kf->P[0][0] = 1.0f; kf->P[0][1] = 0.0f;
    kf->P[1][0] = 0.0f; kf->P[1][1] = 1.0f;
}

// ฟังก์ชันอัปเดต Kalman Filter
void Kalman_Update(KalmanFilter_t *kf, float measured_altitude, float dt_seconds) {
    float predicted_alt = kf->altitude + (kf->velocity * dt_seconds);
    float predicted_vel = kf->velocity;
    
    float P00_pred = kf->P[0][0] + dt_seconds * (kf->P[1][0] + kf->P[0][1]) + dt_seconds * dt_seconds * kf->P[1][1] + (KALMAN_Q_ACCEL * dt_seconds * dt_seconds * dt_seconds * dt_seconds / 4.0f);
    float P01_pred = kf->P[0][1] + dt_seconds * kf->P[1][1] + (KALMAN_Q_ACCEL * dt_seconds * dt_seconds * dt_seconds / 2.0f);
    float P10_pred = kf->P[1][0] + dt_seconds * kf->P[1][1] + (KALMAN_Q_ACCEL * dt_seconds * dt_seconds * dt_seconds / 2.0f);
    float P11_pred = kf->P[1][1] + (KALMAN_Q_ACCEL * dt_seconds * dt_seconds);

    float y = measured_altitude - predicted_alt;
    float S = P00_pred + KALMAN_R_ALT;

    float K0 = P00_pred / S;
    float K1 = P10_pred / S;

    kf->altitude = predicted_alt + (K0 * y);
    kf->velocity = predicted_vel + (K1 * y);

    kf->P[0][0] = (1.0f - K0) * P00_pred;
    kf->P[0][1] = (1.0f - K0) * P01_pred;
    kf->P[1][0] = -K1 * P00_pred + P10_pred;
    kf->P[1][1] = -K1 * P01_pred + P11_pred;
}

