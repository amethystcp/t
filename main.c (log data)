/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_USB_DEVICE_Init();
  /* USER CODE BEGIN 2 */

  /* บังคับให้ขา CS เป็น High ก่อน (โค้ดเดิมของคุณ) */
  HAL_GPIO_WritePin(ICM45686_CS_GPIO_Port, ICM45686_CS_Pin, GPIO_PIN_SET);

  /* สั่งเริ่มต้นการทำงานของเซนเซอร์ (โค้ดเดิมของคุณ) */
  ICM45686_Init(&hspi1);

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  char csv_buffer[128]; // <-- 3. สร้างกล่องข้อความไว้พักข้อมูลก่อนส่งไปคอมพิวเตอร์

  while (1)
  {
      /* อ่านค่าจากเซนเซอร์ 6 แกน (โค้ดเดิมของคุณ) */
      ICM45686_ReadData(&hspi1, &imu_data);

      /* 4. แปลงค่าตัวเลขแกนต่างๆ ออกมาเรียงเป็นข้อความ CSV คั่นด้วยลูกน้ำ และจบด้วยการขึ้นบรรทัดใหม่ (\r\n) */
      int len = sprintf(csv_buffer, "%.2f,%.2f,%.2f,%.2f,%.2f,%.2f\r\n",
                        imu_data.accel_x, imu_data.accel_y, imu_data.accel_z,
                        imu_data.gyro_x,  imu_data.gyro_y,  imu_data.gyro_z);

      /* 5. สั่งพ่นข้อความนี้ ออกไปที่สาย USB Type-C เพื่อวิ่งเข้าคอมพิวเตอร์ */
      CDC_Transmit_FS((uint8_t*)csv_buffer, len);

      /* หน่วงเวลา 50ms (โค้ดเดิมของคุณ) */
      HAL_Delay(50);

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

